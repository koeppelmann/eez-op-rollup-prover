# ─── REQUIRED — get from settler operator ───────────────────────────
L1_RPC=https://rpc.chiadochain.net
L1_CHAIN_ID=10200
ROLLUPS_ADDR=
ROLLUP_MGR_ADDR=
ROLLUP_ID=
DEPOSIT_ADDR=
WITHDRAWAL_ADDR=

# ─── REQUIRED — your prover identity ────────────────────────────────
# Hex private key (0x-prefixed). The address derived from this key:
#   - is the owner + signer of YOUR ECDSAProofSystem (deployed by you)
#   - is what the on-chain verify() will recover sigs to
# Generate with:  cast wallet new
PROVER_KEY=

# ─── FILLED IN BY scripts/deploy_proof_system.sh ────────────────────
# Your deployed ECDSAProofSystem address. The settler operator needs
# to add this to the Rollup manager via addProofSystem before the
# verifier can start.
PROOF_SYSTEM_ADDR=

# ─── L2 EL ──────────────────────────────────────────────────────────
L2_PORT=8547
L2_CHAIN_ID=4242

# Wallets to pre-fund on the local L2 EL with anvil_setBalance. MUST
# match what the settler funds — any divergence shows up as a
# STATE-ROOT MISMATCH on the first batch where one of these wallets
# transacts. CSV of addresses.
PREFUND_WALLETS=

# ─── verifier wiring ────────────────────────────────────────────────
VERIFIER_LISTEN=:9100
START_L1_BLOCK=0
FINALIZATION_DEPTH=12
